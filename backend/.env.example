# Supabase PostgreSQL connection string
# Found in: Supabase Dashboard → Project Settings → Database → Connection String → URI
# Use the "Transaction" mode pooler URL for serverless/free-tier deployments:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Or the direct connection URL:
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Groq API key (free tier) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# NCBI/PubMed API key (optional — increases rate limit from 3 to 10 req/s)
# https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Comma-separated allowed CORS origins
# In production: add your Vercel deployment URL
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
